    {
      "name": "🔍 DRIFT DETECTION",
      "item": [
        {
          "name": "1. Detect All Drift Issues",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/drift/{{projectId}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "drift",
                "{{projectId}}"
              ]
            },
            "description": "Run complete drift analysis on project. Returns:\n- All drift issues found by 5 algorithms\n- Drift score (cumulative severity weighted score)\n- Risk level (Stable/Moderate/High Risk)\n- Issue breakdown by type and severity\n\nAlgorithms:\n1. Version Mismatch: Feature implements older requirement version\n2. Orphan Feature: Feature not linked to any requirement\n3. Implementation Gap: Requirement not implemented by any feature\n4. Testing Gap: Feature with no test cases\n5. Critical Risk: High/Critical priority requirement not implemented"
          },
          "response": []
        },
        {
          "name": "2. Detect Version Mismatch Drift",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/drift/{{projectId}}/Version Mismatch",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "drift",
                "{{projectId}}",
                "Version Mismatch"
              ]
            },
            "description": "Get drift issues of type 'Version Mismatch' - feature implements older requirement version"
          },
          "response": []
        },
        {
          "name": "3. Detect Orphan Features",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/drift/{{projectId}}/Orphan Feature",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "drift",
                "{{projectId}}",
                "Orphan Feature"
              ]
            },
            "description": "Get drift issues of type 'Orphan Feature' - features not linked to any requirement"
          },
          "response": []
        },
        {
          "name": "4. Detect Implementation Gaps",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/drift/{{projectId}}/Implementation Gap",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "drift",
                "{{projectId}}",
                "Implementation Gap"
              ]
            },
            "description": "Get drift issues of type 'Implementation Gap' - requirements not implemented by any feature"
          },
          "response": []
        },
        {
          "name": "5. Detect Testing Gaps",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
