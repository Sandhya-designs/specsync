# Application
NODE_ENV=development
PORT=5000
HOST=localhost

# MongoDB
MONGODB_URI=mongodb://localhost:27017/specsync
MONGODB_LOCAL=mongodb://localhost:27017/specsync

# JWT
JWT_SECRET=your_secure_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info
